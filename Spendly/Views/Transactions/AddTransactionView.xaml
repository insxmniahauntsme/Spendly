<UserControl x:Class="Spendly.Views.Transactions.AddTransactionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Spendly.Controls"
             xmlns:converters="clr-namespace:Spendly.Converters"
             xmlns:enums="clr-namespace:Spendly.Domain.Enums;assembly=Spendly.Domain"
             xmlns:pickers="clr-namespace:Spendly.Controls.Pickers"
             x:Name="Root">

    <UserControl.Resources>
        <converters:EnumEqualsConverter x:Key="EnumEqualsConverter" />

        <Style x:Key="DarkDatePickerTextBoxStyle" TargetType="{x:Type DatePickerTextBox}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
            <Setter Property="FontFamily" Value="Sora" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type DatePickerTextBox}">
                        <Border Background="Transparent"
                                BorderThickness="0"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Background="Transparent"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkDatePickerButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonRoot"
                                CornerRadius="8"
                                Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonRoot"
                                        Property="Background"
                                        Value="{StaticResource Brush.Primary.A10}" />
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonRoot"
                                        Property="Background"
                                        Value="{StaticResource Brush.Primary.A10}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkCalendarDayButtonStyle" TargetType="{x:Type CalendarDayButton}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type CalendarDayButton}">
                        <Border x:Name="DayRoot"
                                Margin="2"
                                CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DayRoot"
                                        Property="Background"
                                        Value="{StaticResource Brush.HoverBg}" />
                            </Trigger>

                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="DayRoot"
                                        Property="Background"
                                        Value="{StaticResource Brush.Primary.A10}" />
                                <Setter TargetName="DayRoot"
                                        Property="BorderBrush"
                                        Value="{StaticResource Brush.Primary.A60}" />
                                <Setter TargetName="DayRoot"
                                        Property="BorderThickness"
                                        Value="1" />
                            </Trigger>

                            <Trigger Property="IsToday" Value="True">
                                <Setter TargetName="DayRoot"
                                        Property="BorderBrush"
                                        Value="{StaticResource Brush.Primary.A60}" />
                                <Setter TargetName="DayRoot"
                                        Property="BorderThickness"
                                        Value="1" />
                            </Trigger>

                            <Trigger Property="IsInactive" Value="True">
                                <Setter Property="Foreground"
                                        Value="{StaticResource Brush.TextMuted}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkCalendarStyle" TargetType="{x:Type Calendar}">
            <Setter Property="Background" Value="{StaticResource Brush.CardBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Calendar}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="10">
                            <CalendarItem x:Name="PART_CalendarItem"
                                          Background="Transparent"
                                          BorderBrush="Transparent"
                                          BorderThickness="0" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkDatePickerStyle" TargetType="{x:Type DatePicker}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
            <Setter Property="FontFamily" Value="Sora" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type DatePicker}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="36" />
                            </Grid.ColumnDefinitions>

                            <DatePickerTextBox x:Name="PART_TextBox"
                                               Style="{StaticResource DarkDatePickerTextBoxStyle}"
                                               Background="Transparent"
                                               Foreground="{StaticResource Brush.TextPrimary}" />

                            <Button x:Name="PART_Button"
                                    Grid.Column="1"
                                    Style="{StaticResource DarkDatePickerButtonStyle}">
                                <controls:SvgIcon Width="18"
                                                  Height="18"
                                                  Source="pack://application:,,,/Resources/Icons/calendar.svg" />
                            </Button>

                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   PopupAnimation="Fade">
                                <Border Margin="0,8,0,0"
                                        Background="{StaticResource Brush.CardBg}"
                                        BorderBrush="{StaticResource Brush.Border}"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <Calendar x:Name="PART_Calendar"
                                              Style="{StaticResource DarkCalendarStyle}"
                                              CalendarDayButtonStyle="{StaticResource DarkCalendarDayButtonStyle}"
                                              Background="{StaticResource Brush.CardBg}"
                                              BorderBrush="{StaticResource Brush.Border}"
                                              Foreground="{StaticResource Brush.TextPrimary}" />
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Backdrop -->
        <Border Background="#800B0B12">
            <Border.InputBindings>
                <MouseBinding MouseAction="LeftClick"
                              Command="{Binding CloseCommand}" />
            </Border.InputBindings>
        </Border>

        <!-- Modal -->
        <Border Width="540"
                MaxWidth="540"
                MinHeight="500"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{StaticResource Brush.CardBg}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="16"
                UseLayoutRounding="True"
                SnapsToDevicePixels="True">

            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="20" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="New transaction"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.TextPrimary}" />
                        <TextBlock Text="Enter transaction details"
                                   Margin="0,4,0,0"
                                   FontSize="11"
                                   Foreground="{StaticResource Brush.TextMuted}" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Width="32"
                            Height="32"
                            Style="{StaticResource OutlineButtonStyle}"
                            Command="{Binding CloseCommand}"
                            Content="✕" />
                </Grid>

                <!-- Type -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <RadioButton Grid.Column="0"
                                 Margin="0"
                                 Content="Expense"
                                 Style="{StaticResource OutlineRadioButtonStyle}"
                                 IsChecked="{Binding Type,
                                                     Converter={StaticResource EnumEqualsConverter},
                                                     ConverterParameter={x:Static enums:TransactionType.Expense}}" />

                    <RadioButton Grid.Column="2"
                                 Margin="0"
                                 Content="Income"
                                 Style="{StaticResource OutlineRadioButtonStyle}"
                                 IsChecked="{Binding Type,
                                                     Converter={StaticResource EnumEqualsConverter},
                                                     ConverterParameter={x:Static enums:TransactionType.Income}}" />
                </Grid>

                <!-- Amount -->
                <StackPanel Grid.Row="4">
                    <TextBlock Text="AMOUNT"
                               Style="{StaticResource Caption}"
                               Margin="0,0,0,8" />

                    <Border Height="48"
                            CornerRadius="10"
                            Background="{StaticResource Brush.HoverBg}"
                            BorderBrush="{StaticResource Brush.Border}"
                            BorderThickness="1"
                            Padding="14,0">
                        <TextBox Background="Transparent"
                                 BorderThickness="0"
                                 VerticalContentAlignment="Center"
                                 FontSize="18"
                                 FontWeight="SemiBold"
                                 Foreground="{StaticResource Brush.TextPrimary}"
                                 CaretBrush="{StaticResource Brush.TextPrimary}"
                                 Text="{Binding Amount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Border>
                </StackPanel>

                <!-- Category -->
                <StackPanel Grid.Row="6">
                    <TextBlock Text="CATEGORY"
                               Style="{StaticResource Caption}"
                               Margin="0,0,0,8" />

                    <pickers:CategoryPicker ItemsSource="{Binding Categories}"
                                            Width="Auto"
                                            SelectedValue="{Binding SelectedCategoryId, Mode=TwoWay}"
                                            IsOpen="{Binding IsCategoryPickerOpen, Mode=TwoWay}"
                                            Title="{Binding CategoryTitle}"
                                            IconSource="{Binding CategoryIcon}" />
                </StackPanel>

                <!-- Comment + Date -->
                <Grid Grid.Row="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="210" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="NAME / DESCRIPTION"
                                   Style="{StaticResource Caption}"
                                   Margin="0,0,0,8" />

                        <Border Height="48"
                                CornerRadius="10"
                                Background="{StaticResource Brush.HoverBg}"
                                BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1"
                                Padding="14,0">
                            <TextBox Background="Transparent"
                                     BorderThickness="0"
                                     VerticalContentAlignment="Center"
                                     FontSize="14"
                                     Foreground="{StaticResource Brush.TextPrimary}"
                                     CaretBrush="{StaticResource Brush.TextPrimary}"
                                     Text="{Binding Comment, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="DATE"
                                   Style="{StaticResource Caption}"
                                   Margin="0,0,0,8" />

                        <Border Height="48"
                                CornerRadius="10"
                                Background="{StaticResource Brush.HoverBg}"
                                BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1"
                                Padding="14,0">
                            <DatePicker Style="{StaticResource DarkDatePickerStyle}"
                                        SelectedDate="{Binding SelectedDate, Mode=TwoWay}" />
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Account -->
                <StackPanel Grid.Row="10">
                    <TextBlock Text="ACCOUNT"
                               Style="{StaticResource Caption}"
                               Margin="0,0,0,8" />

                    <pickers:AccountPicker ItemsSource="{Binding Accounts}"
                                           SelectedValue="{Binding SelectedAccountId, Mode=TwoWay}"
                                           Width="Auto"
                                           IsOpen="{Binding IsAccountPickerOpen, Mode=TwoWay}"
                                           Title="{Binding AccountTitle}" />
                </StackPanel>

                <!-- Save -->
                <Button Grid.Row="12"
                        Height="44"
                        Style="{StaticResource GradientButtonStyle}"
                        Command="{Binding SaveCommand}"
                        Content="Save transaction" />
            </Grid>
        </Border>
    </Grid>
</UserControl>