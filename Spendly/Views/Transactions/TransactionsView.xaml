<UserControl x:Class="Spendly.Views.Transactions.TransactionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Spendly.Controls"
             xmlns:dashboard="clr-namespace:Spendly.Controls.Dashboard"
             xmlns:converters="clr-namespace:Spendly.Converters"
             xmlns:local="clr-namespace:Spendly.ViewModels.Transactions"
             xmlns:pickers="clr-namespace:Spendly.Controls.Pickers"
             xmlns:dataEnums="clr-namespace:Spendly.Data.Enums;assembly=Spendly.Domain">

    <UserControl.Resources>
        <converters:EnumEqualsConverter x:Key="EnumEqualsConverter" />
    </UserControl.Resources>

    <Grid Background="{StaticResource Brush.MainBg}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="20,16,20,16">

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="270" />
                    </Grid.ColumnDefinitions>

                    <WrapPanel VerticalAlignment="Center">
                        <RadioButton Style="{StaticResource OutlineRadioButtonStyle}"
                                     GroupName="TransactionType"
                                     Width="52"
                                     Content="All"
                                     IsChecked="{Binding SelectedTypeFilter,
                                                         Converter={StaticResource EnumEqualsConverter},
                                                         ConverterParameter={x:Static local:TransactionTypeFilter.All}}"
                                     Command="{Binding SetAllCommand}" />

                        <RadioButton Style="{StaticResource OutlineRadioButtonStyle}"
                                     GroupName="TransactionType"
                                     Width="82"
                                     Content="Expenses"
                                     IsChecked="{Binding SelectedTypeFilter,
                                                         Converter={StaticResource EnumEqualsConverter},
                                                         ConverterParameter={x:Static local:TransactionTypeFilter.Expenses}}"
                                     Command="{Binding SetExpensesCommand}" />

                        <RadioButton Style="{StaticResource OutlineRadioButtonStyle}"
                                     GroupName="TransactionType"
                                     Width="72"
                                     Content="Incomes"
                                     IsChecked="{Binding SelectedTypeFilter,
                                                         Converter={StaticResource EnumEqualsConverter},
                                                         ConverterParameter={x:Static local:TransactionTypeFilter.Income}}"
                                     Command="{Binding SetIncomeCommand}" />

                        <pickers:MonthPicker
                            SelectedMonth="{Binding SelectedMonth, Mode=TwoWay}"
                            ButtonStyle="{StaticResource OutlineToggleButtonStyle}"
                            NavButtonStyle="{StaticResource MonthPickerNavButtonStyle}" />

                        <pickers:CategoryPicker
                            ItemsSource="{Binding Categories}"
                            SelectedValue="{Binding SelectedCategoryId, Mode=TwoWay}"
                            IsOpen="{Binding IsCategoryPickerOpen, Mode=TwoWay}"
                            Title="{Binding CategoryTitle}"
                            IconSource="{Binding CategoryIcon}" />

                        <pickers:AccountPicker
                            ItemsSource="{Binding Accounts}"
                            SelectedValue="{Binding SelectedAccountId, Mode=TwoWay}"
                            IsOpen="{Binding IsAccountPickerOpen, Mode=TwoWay}"
                            Title="{Binding AccountTitle}" />
                    </WrapPanel>

                    <Border Grid.Column="1"
                            Height="35"
                            CornerRadius="8"
                            Background="{StaticResource Brush.CardBg}"
                            BorderBrush="{StaticResource Brush.Border}"
                            BorderThickness="1"
                            Padding="10,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <controls:SvgIcon Width="18"
                                              Height="18"
                                              VerticalAlignment="Center"
                                              Source="pack://application:,,,/Resources/Icons/magnifying-glass.svg" />

                            <Grid Grid.Column="2">
                                <TextBlock Text="Search transactions..."
                                           Margin="2,0,0,0"
                                           Foreground="{StaticResource Brush.TextMuted}"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"
                                           Panel.ZIndex="0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}"
                                                             Value="">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}"
                                                             Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <TextBox x:Name="SearchTextBox"
                                         Panel.ZIndex="1"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="{StaticResource Brush.TextPrimary}"
                                         CaretBrush="{StaticResource Brush.TextPrimary}"
                                         VerticalContentAlignment="Center"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <UniformGrid Columns="3" Margin="0,0,0,12">
                    <dashboard:KpiCard Margin="0,0,12,0"
                                       Variant="Primary"
                                       Title="Records shown"
                                       ValueText="{Binding RecordsShownText}" />

                    <dashboard:KpiCard Margin="0,0,12,0"
                                       Variant="Danger"
                                       Title="Total expenses"
                                       ValueText="{Binding TotalExpensesText}" />

                    <dashboard:KpiCard Margin="0,0,0,0"
                                       Variant="Success"
                                       Title="Total income"
                                       ValueText="{Binding TotalIncomeText}" />
                </UniformGrid>

                <Border CornerRadius="12"
                        Background="{StaticResource Brush.CardBg}"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1"
                        Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="1.4*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="NAME / CATEGORY" Style="{StaticResource Caption}" />
                            <TextBlock Grid.Column="1" Text="AMOUNT" Style="{StaticResource Caption}" />
                            <TextBlock Grid.Column="2" Text="ACCOUNT" Style="{StaticResource Caption}" />
                            <TextBlock Grid.Column="3" Text="DATE" Style="{StaticResource Caption}" />
                            <TextBlock Grid.Column="4"
                                       Text="ACTIONS"
                                       Style="{StaticResource Caption}"
                                       HorizontalAlignment="Right" />
                        </Grid>

                        <ItemsControl Grid.Row="2"
                                      ItemsSource="{Binding Transactions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="0,11"
                                            BorderBrush="{StaticResource Brush.Border}"
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="3*" />
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="1.4*" />
                                            </Grid.ColumnDefinitions>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <controls:SvgIcon Grid.Column="0"
                                                                  Width="22"
                                                                  Height="22"
                                                                  VerticalAlignment="Center"
                                                                  Source="{Binding CategoryIconSource}" />

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="{Binding Comment}"
                                                               FontSize="13"
                                                               Foreground="{StaticResource Brush.TextPrimary}" />
                                                    <TextBlock Text="{Binding CategoryName}"
                                                               Style="{StaticResource Caption}" />
                                                </StackPanel>
                                            </Grid>

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding AmountText}"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground"
                                                                Value="{StaticResource Brush.Success}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Type}" Value="Expense">
                                                                <Setter Property="Foreground"
                                                                        Value="{StaticResource Brush.Danger}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding AccountName}"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource Brush.TextPrimary}" />

                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding DateText}"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource Brush.TextPrimary}" />

                                            <WrapPanel Grid.Column="4"
                                                       Margin="0,5,0,0"
                                                       HorizontalAlignment="Right">

                                                <Button Style="{StaticResource IconActionButtonStyle}"
                                                        Command="{Binding DataContext.OpenEditTransactionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <controls:SvgIcon Width="22"
                                                                      Height="22"
                                                                      Source="pack://application:,,,/Resources/Icons/edit-pencil.svg" />
                                                </Button>

                                                <Button Margin="6,0,0,0"
                                                        Style="{StaticResource IconActionButtonStyle}"
                                                        Command="{Binding DataContext.DeleteTransactionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding Id}">
                                                    <controls:SvgIcon Width="22"
                                                                      Height="22"
                                                                      Source="pack://application:,,,/Resources/Icons/trash-bin.svg" />
                                                </Button>

                                            </WrapPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding ShowingText}"
                                       Style="{StaticResource Caption}"
                                       VerticalAlignment="Center" />

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Style="{StaticResource PaginationArrowButtonStyle}"
                                        Content="‹"
                                        Command="{Binding GoToPreviousPageCommand}"
                                        IsEnabled="{Binding CanGoPrevious}" />

                                <ItemsControl ItemsSource="{Binding VisiblePages}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <TextBlock Text="{Binding Text}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock"
                                                               BasedOn="{StaticResource PaginationEllipsisTextStyle}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEllipsis}"
                                                                             Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <Button Content="{Binding Text}"
                                                        Command="{Binding DataContext.GoToPageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding Page}">
                                                    <Button.Style>
                                                        <Style TargetType="Button"
                                                               BasedOn="{StaticResource PaginationPageButtonStyle}">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEllipsis}"
                                                                             Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>

                                                                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                                    <Setter Property="Background"
                                                                            Value="{StaticResource Brush.Primary.A10}" />
                                                                    <Setter Property="BorderBrush"
                                                                            Value="{StaticResource Brush.Primary.A60}" />
                                                                    <Setter Property="Foreground"
                                                                            Value="{StaticResource Brush.PrimaryLight}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Button Style="{StaticResource PaginationArrowButtonStyle}"
                                        Margin="0"
                                        Content="›"
                                        Command="{Binding GoToNextPageCommand}"
                                        IsEnabled="{Binding CanGoNext}" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>