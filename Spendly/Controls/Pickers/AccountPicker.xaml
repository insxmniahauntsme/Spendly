<UserControl x:Class="Spendly.Controls.Pickers.AccountPicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Spendly.Controls"
             x:Name="Root">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/TransactionFilters.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <!-- Top chip -->
        <ToggleButton x:Name="DropButton"
                      Style="{StaticResource TxnFilterChipToggleStyle}"
                      Width="106"
                      IsChecked="{Binding ElementName=Root, Path=IsOpen, Mode=TwoWay}"
                      PreviewMouseRightButtonUp="DropButton_OnPreviewMouseRightButtonUp">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <controls:SvgIcon Width="16"
                                  Height="16"
                                  Margin="0,0,8,0"
                                  Source="pack://application:,,,/Resources/Icons/credit-card.svg" />

                <TextBlock Style="{StaticResource TxnFilterChipTextStyle}"
                           Text="{Binding ElementName=Root, Path=Title}" />
            </StackPanel>
        </ToggleButton>

        <!-- Popup -->
        <Popup PlacementTarget="{Binding ElementName=DropButton}"
               Placement="Bottom"
               AllowsTransparency="True"
               StaysOpen="False"
               VerticalOffset="10"
               IsOpen="{Binding ElementName=Root, Path=IsOpen, Mode=TwoWay}"
               DataContext="{Binding ElementName=Root}">

            <Border Style="{StaticResource MonthPickerPopupBorderStyle}"
                    Padding="4"
                    Width="240"
                    MinWidth="240">

                <StackPanel>
                    <!-- Header -->
                    <TextBlock Text="Account"
                               Style="{StaticResource MonthPickerHeaderTextStyle}"
                               Margin="0,0,0,10" />

                    <!-- List -->
                    <ListBox ItemsSource="{Binding ItemsSource}"
                             SelectedValuePath="Id"
                             SelectedValue="{Binding SelectedValue, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0"
                             MaxHeight="260"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                        <ListBox.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource TxnScrollBarStyle}" />
                        </ListBox.Resources>

                        <!-- pill rows -->
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Height" Value="34"/>
                                <Setter Property="Margin" Value="0,0,0,8"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="Cursor" Value="Hand"/>

                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd"
                                                    CornerRadius="10"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}">
                                                <ContentPresenter VerticalAlignment="Center"
                                                                  Margin="12,0"/>
                                            </Border>

                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd"
                                                            Property="Background"
                                                            Value="{StaticResource Brush.HoverBg}"/>
                                                </Trigger>

                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd"
                                                            Property="Background"
                                                            Value="{StaticResource Brush.Primary.A10}"/>
                                                    <Setter TargetName="Bd"
                                                            Property="BorderBrush"
                                                            Value="{StaticResource Brush.Primary.A60}"/>
                                                </Trigger>

                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.5"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <!-- row content -->
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- optional icon from VM -->
                                    <controls:SvgIcon Grid.Column="0"
                                                      Width="16" Height="16"
                                                      VerticalAlignment="Center"
                                                      Source="{Binding IconSource}"/>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Name}"
                                               Margin="10,0,0,0"
                                               FontFamily="Sora"
                                               FontSize="12.5"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource Brush.TextPrimary}"
                                               VerticalAlignment="Center"/>

                                    <!-- optional badge (e.g. bank) -->
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Tag}"
                                               Margin="12,0,0,0"
                                               FontFamily="Sora"
                                               FontSize="11.5"
                                               Foreground="{StaticResource Brush.TextMuted}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>

                    </ListBox>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>