<UserControl x:Class="Spendly.Controls.Notifications.ToastView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:notifications="clr-namespace:Spendly.Controls.Notifications"
             x:Name="Root">
    <Border x:Name="RootBorder"
            MinWidth="280"
            MaxWidth="320"
            MinHeight="60"
            CornerRadius="10"
            Background="{StaticResource Brush.CardBg}"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="1">
        <Grid>
            <Border x:Name="AccentBar"
                    Width="5"
                    CornerRadius="10,0,0,10"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Stretch"
                    Margin="0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource Brush.Primary}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ElementName=Root, Path=Variant}"
                                         Value="{x:Static notifications:ToastVariant.Success}">
                                <Setter Property="Background" Value="{StaticResource Brush.Success}" />
                            </DataTrigger>

                            <DataTrigger Binding="{Binding ElementName=Root, Path=Variant}"
                                         Value="{x:Static notifications:ToastVariant.Danger}">
                                <Setter Property="Background" Value="{StaticResource Brush.Danger}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>
            <Grid Margin="10,8,10,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Main clickable surface -->
                <Button Grid.Column="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0"
                        Command="{Binding ElementName=Root, Path=Command}"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="IsEnabled" Value="{Binding ElementName=Root, Path=IsClickable}" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="Opacity" Value="1" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="ClickSurface"
                                                Background="Transparent"
                                                CornerRadius="8">
                                            
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Border Width="24"
                                                        Height="24"
                                                        CornerRadius="12"
                                                        VerticalAlignment="Center"
                                                        Margin="6,0,0,0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background"
                                                                    Value="{StaticResource Brush.Primary.A10}" />
                                                            <Style.Triggers>
                                                                <DataTrigger
                                                                    Binding="{Binding ElementName=Root, Path=Variant}"
                                                                    Value="{x:Static notifications:ToastVariant.Success}">
                                                                    <Setter Property="Background"
                                                                            Value="{StaticResource Brush.Success.A10}" />
                                                                </DataTrigger>
                                                                <DataTrigger
                                                                    Binding="{Binding ElementName=Root, Path=Variant}"
                                                                    Value="{x:Static notifications:ToastVariant.Danger}">
                                                                    <Setter Property="Background"
                                                                            Value="{StaticResource Brush.Danger.A10}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>

                                                    <TextBlock FontSize="12"
                                                               FontWeight="Bold"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="i" />
                                                                <Setter Property="Foreground"
                                                                        Value="{StaticResource Brush.Primary}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger
                                                                        Binding="{Binding ElementName=Root, Path=Variant}"
                                                                        Value="{x:Static notifications:ToastVariant.Success}">
                                                                        <Setter Property="Text" Value="✓" />
                                                                        <Setter Property="Foreground"
                                                                                Value="{StaticResource Brush.Success}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger
                                                                        Binding="{Binding ElementName=Root, Path=Variant}"
                                                                        Value="{x:Static notifications:ToastVariant.Danger}">
                                                                        <Setter Property="Text" Value="!" />
                                                                        <Setter Property="Foreground"
                                                                                Value="{StaticResource Brush.Danger}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>

                                                <StackPanel Grid.Column="2"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ElementName=Root, Path=Title}"
                                                               FontFamily="Sora"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource Brush.TextPrimary}" />

                                                    <TextBlock Text="{Binding ElementName=Root, Path=Message}"
                                                               Margin="0,5,0,0"
                                                               FontFamily="Sora"
                                                               FontSize="11"
                                                               Foreground="{StaticResource Brush.TextMuted}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ClickSurface" Property="Opacity" Value="0.96" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="ClickSurface" Property="Opacity" Value="0.88" />
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Cursor" Value="Arrow" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Close button -->
                <Button Grid.Column="2"
                        Width="28"
                        Height="28"
                        Command="{Binding ElementName=Root, Path=CloseCommand}"
                        Content="✕">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource OutlineButtonStyle}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=Root, Path=IsClosable}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Grid>
    </Border>
</UserControl>