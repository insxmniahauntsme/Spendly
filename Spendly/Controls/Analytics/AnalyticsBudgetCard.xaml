<UserControl x:Class="Spendly.Controls.Analytics.AnalyticsBudgetCard"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:Spendly.Controls"
             xmlns:converters="clr-namespace:Spendly.Converters"
             mc:Ignorable="d">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
    </UserControl.Resources>

    <Border x:Name="RootBorder"
            CornerRadius="12"
            Background="{StaticResource Brush.CardBg}"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="1">
        <Border.Clip>
            <MultiBinding Converter="{StaticResource ClipRectConverter}">
                <Binding ElementName="RootBorder" Path="ActualWidth" />
                <Binding ElementName="RootBorder" Path="ActualHeight" />
                <Binding ElementName="RootBorder" Path="CornerRadius" />
            </MultiBinding>
        </Border.Clip>
        <Grid ClipToBounds="True">

            <!-- Glow -->
            <Ellipse x:Name="Glow"
                     Width="260"
                     Height="220"
                     Margin="0,-135,-135,0"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Top"
                     Opacity="0.55"
                     IsHitTestVisible="False">
                <Ellipse.Fill>
                    <RadialGradientBrush Center="0.5,0.5"
                                         GradientOrigin="0.5,0.5"
                                         RadiusX="0.5"
                                         RadiusY="0.5">
                        <GradientStop Color="{StaticResource Spendly.Primary.A60}" Offset="0.0" />
                        <GradientStop Color="{StaticResource Spendly.Primary.A10}" Offset="0.45" />
                        <GradientStop Color="Transparent" Offset="1.0" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <BlurEffect Radius="20" />
                </Ellipse.Effect>
            </Ellipse>

            <!-- Soft top overlay -->
            <Rectangle Opacity="0.20"
                       IsHitTestVisible="False">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#22FFFFFF" Offset="0.0" />
                        <GradientStop Color="Transparent" Offset="0.7" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <Grid Margin="16">

                <!-- NORMAL CONTENT -->
                <Grid x:Name="ContentGrid"
                      Visibility="{Binding HasData, ElementName=Root, Converter={StaticResource BoolToVisibility}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="8" />
                    </Grid.RowDefinitions>

                    <!-- Badge -->
                    <Border x:Name="Badge"
                            Grid.Row="0"
                            HorizontalAlignment="Left"
                            CornerRadius="6"
                            Padding="10,5"
                            Background="{StaticResource Brush.PrimaryOverlay}">
                        <TextBlock Text="{Binding BadgeText, ElementName=Root}"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding AccentBrush, ElementName=Root}" />
                    </Border>

                    <!-- Icon + title -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                        <controls:SvgIcon Width="18"
                                          Height="18"
                                          Source="{Binding IconSource, ElementName=Root}" />

                        <TextBlock Margin="8,0,0,0"
                                   Text="{Binding Title, ElementName=Root}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.TextPrimary}" />
                    </StackPanel>

                    <!-- Amount -->
                    <TextBlock Grid.Row="4"
                               FontSize="14"
                               Foreground="{StaticResource Brush.TextMuted}">
                        <Run Text="{Binding CurrentText, ElementName=Root}"
                             FontSize="20"
                             Foreground="{Binding AccentBrush, ElementName=Root}" />
                        <Run Text="  /  " />
                        <Run Text="{Binding LimitText, ElementName=Root}" />
                    </TextBlock>

                    <!-- Progress -->
                    <Grid x:Name="ProgressHost"
                          Grid.Row="6"
                          Height="6"
                          SizeChanged="ProgressHost_OnSizeChanged">
                        <Border Background="#171722" CornerRadius="3" />

                        <Border x:Name="ProgressFill"
                                HorizontalAlignment="Left"
                                CornerRadius="3"
                                Background="{Binding AccentBrush, ElementName=Root}" />
                    </Grid>
                </Grid>

                <!-- EMPTY CONTENT -->
                <Grid x:Name="EmptyGrid"
                      Visibility="{Binding HasData, ElementName=Root, Converter={StaticResource InverseBoolToVisibility}}">
                    <StackPanel VerticalAlignment="Center">

                        <Border HorizontalAlignment="Left"
                                CornerRadius="6"
                                Padding="10,5"
                                Background="{StaticResource Brush.NeutralOverlay}">
                            <TextBlock Text="{Binding BadgeText, ElementName=Root}"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.TextMuted}" />
                        </Border>

                        <TextBlock Margin="0,16,0,0"
                                   Text="{Binding Title, ElementName=Root}"
                                   FontSize="13"
                                   Foreground="{StaticResource Brush.TextPrimary}" />

                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>